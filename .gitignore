# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# Virtualenvs
venv/
.venv/
env/
.env/

# Environment files — keep .env.example, exclude actual secrets
.env
.env.local

# PyInstaller / Inno Setup build outputs
build/
dist/
*.spec.bak

# User data (projects with potentially client-identifiable info)
data/projects/*.json
!data/projects/.gitkeep

# Logs
logs/
*.log

# Editors / IDEs
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Sample / scratch documents — never commit client files
*.docx
*.pptx
*.xlsx
*.pdf
